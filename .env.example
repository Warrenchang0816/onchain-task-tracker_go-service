# ============================================================
# go-service 環境變數範本
# 使用方式：cp .env.example .env，再填入真實值
#
# ⚠️  .env 已在 .gitignore 中排除，絕對不可提交至 Git
# ⚠️  APP_PLATFORM_OPERATOR_PRIVATE_KEY 為高敏感資訊，請妥善保管
# ============================================================


# ────────────────────────────────────────────────
# 資料庫（PostgreSQL）
# DB_PASS 必須與 infra/.env 的 POSTGRES_PASSWORD 一致
# ────────────────────────────────────────────────
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password_here
DB_NAME=TASK
DB_SSLMODE=disable


# ────────────────────────────────────────────────
# SIWE 認證（Sign-In with Ethereum）
#
# APP_DOMAIN / APP_URI：前端的網域與完整 URL
#   本機開發固定填 localhost:5173 / http://localhost:5173
#   正式環境需改為實際網域
#
# SIWE_CHAIN_ID：必須與前端 MetaMask 使用的鏈一致
#   Sepolia = 11155111 | Base Sepolia = 84532 | Base 主網 = 8453
#
# AUTH_SESSION_SECURE：
#   本機開發填 false（HTTP）；正式環境 HTTPS 時改為 true
# ────────────────────────────────────────────────
APP_DOMAIN=localhost:5173
APP_URI=http://localhost:5173
SIWE_STATEMENT=Sign in to On-chain Task Tracker.
SIWE_VERSION=1
SIWE_CHAIN_ID=11155111
SIWE_NONCE_EXPIRE=300
AUTH_SESSION_EXPIRE=86400
AUTH_COOKIE_NAME=go_service_session
AUTH_SESSION_SECURE=false


# ────────────────────────────────────────────────
# 區塊鏈設定
#
# APP_CHAIN_ID：目標鏈的 Chain ID（需與 SIWE_CHAIN_ID 一致）
#
# APP_RPC_URL：Alchemy（或 Infura）的 HTTPS RPC endpoint
#   申請方式：https://www.alchemy.com → Create App → Ethereum Sepolia
#   格式：https://eth-sepolia.g.alchemy.com/v2/<YOUR_API_KEY>
#
# APP_REWARD_VAULT_ADDRESS：已部署的 TaskRewardVault 合約地址
#   部署後從 Foundry 輸出的 "Deployed to: 0x..." 取得
#
# APP_PLATFORM_FEE_BPS：平台手續費基點（100 = 1%，500 = 5%）
#
# APP_PLATFORM_TREASURY_ADDRESS：收取手續費的平台錢包地址
#
# APP_PLATFORM_OPERATOR_PRIVATE_KEY：
#   ⚠️  最高敏感度：後端用此私鑰自動簽署 assignWorker / approveTask
#   格式：0x 開頭的 64 位 hex 字串
#   不可截圖、不可傳訊息、不可 hardcode 進程式碼
#
# APP_GOD_MODE_WALLET_ADDRESS：
#   可強制更新任何任務狀態的超級權限錢包（僅限開發除錯）
#   正式上線前應設為空字串或移除此功能
# ────────────────────────────────────────────────
APP_CHAIN_ID=11155111
APP_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key_here
APP_REWARD_VAULT_ADDRESS=0xYourContractAddressHere
APP_PLATFORM_FEE_BPS=500
APP_PLATFORM_TREASURY_ADDRESS=0xYourTreasuryWalletAddressHere
APP_PLATFORM_OPERATOR_PRIVATE_KEY=0xYourOperatorPrivateKeyHere
APP_GOD_MODE_WALLET_ADDRESS=0xYourGodModeWalletAddressHere
